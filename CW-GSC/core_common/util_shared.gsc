    if(elapsed_time > largest_elapsed_time) {
      largest_elapsed_time = elapsed_time;
    }
  }

  average_elapsed_time = total_elapsed_time / elapsed_time_array.size;
  msg = label + "<dev string:x99e>" + smallest_elapsed_time + "<dev string:x9bf>" + average_elapsed_time + "<dev string:x9bf>" + largest_elapsed_time + "<dev string:x9c6>" + elapsed_time_array.size;
