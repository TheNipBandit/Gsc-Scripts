    if(score == var_daf8d664) {
      waitframe(1);
    }
  }

  while(true) {
    if(getdvarint(#"hash_3a3f995b08f2b9b8", -1) != -1) {
      var_6d2040ea = getdvarint(#"hash_3a3f995b08f2b9b8", -1);
      var_14f1a63 = (int(var_6d2040ea * 1000) + globallogic_utils::gettimepassed()) / int(60 * 1000);

      if(var_6d2040ea == 0) {
        var_14f1a63 = 0;
