      if(hotstreakstage != -1) {
        player clientfield::set_player_uimodel("<dev string:x6af>", hotstreakstage);
      }
    }

    setDvar(#"hash_649ea18bd5e55893", -1);
    setDvar(#"hash_6ad3f58a8e0a1e59", -1);
  }
}

